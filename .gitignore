# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma (SQLite)
/generated/prisma
*.db
*.db-journal

# runtime alert state (one e-mail per outage)
data/media-missing-alert.json
data/backup-failure-alert.json

# data folders
public/thumbnails/*
!public/thumbnails/.gitkeep
public/videos/*
!public/videos/.gitkeep
backups/

# website
/website/
/Website/

# VS Code & Workspace
*.code-workspace
.vscode/

# Temp files
tmp_*
ultimate_truth.ts
